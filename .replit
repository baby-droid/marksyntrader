modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node node_modules/@rsbuild/core/bin/rsbuild.js dev --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[userenv]

[userenv.shared]
NEXT_PUBLIC_DERIV_REDIRECT_URI = "https://marksyntrader.replit.app/callback"
NEXT_PUBLIC_DERIV_ENV = "production"
NEXT_PUBLIC_DERIV_APP_NAME = "Marksyntrader"
NEXT_PUBLIC_DERIV_APP_ID = "33FxUklO31bUSd9GkznBN"
